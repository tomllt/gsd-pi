{
  "name": "@opengsd/cloud-mcp-gateway",
  "version": "1.0.2",
  "description": "Cloud MCP gateway for brokering remote MCP clients to local GSD runtimes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-gsd/gsd-pi.git",
    "directory": "packages/cloud-mcp-gateway"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "gsd-cloud-mcp-gateway": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "pnpm run build && node --test dist/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opengsd/mcp-server": "workspace:*",
    "ws": "^8.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "README.md",
    "dist",
    "!dist/**/*.test.*"
  ]
