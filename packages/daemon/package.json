{
  "name": "@opengsd/daemon",
  "version": "1.2.0",
  "description": "GSD daemon — background process for project monitoring and Discord integration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/open-gsd/gsd-pi.git",
    "directory": "packages/daemon"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "gsd-daemon": "./bin/gsd-daemon.js",
    "gsd-mcp": "./bin/gsd-mcp.js",
    "gsd-mcp-runtime": "./bin/gsd-mcp-runtime.js"
  },
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.cjs && tsc",
    "test": "node --test dist/daemon.test.js dist/cloud-config.test.js dist/cloud-runtime.test.js dist/local-tool-executor.test.js dist/mcp-cli.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@opengsd/contracts": "workspace:*",
    "@opengsd/mcp-server": "workspace:*",
    "@opengsd/rpc-client": "workspace:*",
    "discord.js": "^14.25.1",
    "ws": "^8.20.0",
    "yaml": "^2.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "bin",
    "dist",
    "!dist/**/*.test.*"
  ]
}
